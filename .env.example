# ── 必填 ──────────────────────────────────────────────────
# Claude API key（兼容 deepseek-v4-pro 等 Anthropic 兼容模型）
ANTHROPIC_API_KEY=sk-ant-xxx

# 163 邮箱（仅 AI News 发布引擎需要，YouTube 蒸馏器不需要）
EMAIL_163_USER=your@163.com
EMAIL_163_PASS=your-imap-auth-code

# ── 可选：API 后端切换 ────────────────────────────────────
# 默认用 deepseek-v4-pro[1m]，换成 Anthropic 官方：
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── 可选：GitHub API ──────────────────────────────────────
# 提高 GitHub Trending 抓取频率限制（不配也能用，只是限制更严）
# GITHUB_TOKEN=ghp_xxx

# ── 可选：飞书推送 ────────────────────────────────────────
# FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/xxx

# ── 可选：Vercel 部署 ─────────────────────────────────────
# VERCEL_URL=https://claude-test-blush.vercel.app
